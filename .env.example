# ===== 中継サーバ設定テンプレート =====
# このファイルをコピーして .env を作成し、実際の値を入れてください（.env はGit管理外）。
#   cp .env.example .env

# --- 動作モード: DRY_RUN | TESTNET | LIVE ---
# DRY_RUN : 発注せずログ＆通知のみ（Phase 1）
# TESTNET : テストネットへ実発注（Phase 2, 例: bybit sandbox）
# LIVE    : 本番取引所へ実発注（Phase 3, 極小サイズ推奨）
TRADING_MODE=DRY_RUN

# --- TradingView Webhook と共有する秘密鍵（Pineのメッセージ内 secret と一致させる） ---
WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Discord 通知 ---
DISCORD_WEBHOOK_URL=

# --- 取引所（ccxt の exchange id）---
# Phase 2(TESTNET)は bybit（テストネットあり）で検証。
# Phase 3(LIVE)は bitbank（アルトの板取引が国内最大級・ccxt対応）。
#   検証中: EXCHANGE_ID=bybit   本番: EXCHANGE_ID=bitbank
EXCHANGE_ID=bybit
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# --- リスク制御 ---
# 1回の発注に使う固定額（ORDER_SIZE_PCT=0 の時に使用）
ORDER_QUOTE_AMOUNT=1000
# 発注額を「総資産のこの割合」にする（資金が足りなければある分だけ）。0=固定額。例 0.10=10%
ORDER_SIZE_PCT=0.10
# これ未満の発注額なら資金不足として見送り（0=チェックなし）
MIN_ORDER_JPY=100
# 同時に持てる最大建玉数（複数銘柄を並行で持つ数）
MAX_OPEN_POSITIONS=3
# 同一シンボル+方向でこの秒数以内の連続発注を無視（二重/連打防止）
ORDER_COOLDOWN_SEC=60
# 損切り: 取得単価からこの割合下落したら自動で成行決済（0=無効）。例 0.05=5%
STOP_LOSS_PCT=0.05
# 利確: 取得単価からこの割合上昇したら自動で成行決済（0=無効）。例 0.05=5%
TAKE_PROFIT_PCT=0.05
# 価格監視ループの間隔（秒）
MONITOR_INTERVAL_SEC=60
# 1日の実現損失がこの額(JPY)を超えたら当日は新規買い停止（0=無効。下のPCTのフォールバック）
MAX_DAILY_LOSS_JPY=0
# 1日の実現損失が「総資産×この割合」を超えたら停止（0=無効・JPYより優先）。例 0.08=8%
MAX_DAILY_LOSS_PCT=0.08
# 取引時間帯(JST)。空=24時間。例 "8-24"
TRADING_HOURS=
# 1日の新規エントリー回数の上限（0=無効）
MAX_TRADES_PER_DAY=0
# 許可するシンボル（カンマ区切り）。ここに無いシンボルは拒否。
# ※これは「変換後（取引所ペア）」の表記で書く。本番bitbankならJPYペア。
#   bitbankの主なJPY板: BTC/JPY,ETH/JPY,XRP/JPY,SOL/JPY,DOGE/JPY,ADA/JPY,LTC/JPY,DOT/JPY ...
ALLOWED_SYMBOLS=XRP/JPY,ETH/JPY,SOL/JPY,DOGE/JPY,LTC/JPY,DOT/JPY,LINK/JPY,AVAX/JPY,ATOM/JPY,XLM/JPY

# TradingViewの銘柄表記 → 取引所ペア への変換表（"TV表記=取引所ペア" をカンマ区切り）。
# 例: TradingViewのBINANCE:XRPUSDTチャートは {{ticker}}="XRPUSDT" を送るので XRP/JPY に変換する。
SYMBOL_MAP=XRPUSDT=XRP/JPY,ETHUSDT=ETH/JPY,SOLUSDT=SOL/JPY,DOGEUSDT=DOGE/JPY,LTCUSDT=LTC/JPY,DOTUSDT=DOT/JPY,LINKUSDT=LINK/JPY,AVAXUSDT=AVAX/JPY,ATOMUSDT=ATOM/JPY,XLMUSDT=XLM/JPY

# --- サーバ ---
HOST=0.0.0.0
PORT=8000
