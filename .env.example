# ===== 中継サーバ設定テンプレート =====
# このファイルをコピーして .env を作成し、実際の値を入れてください（.env はGit管理外）。
#   cp .env.example .env

# --- 動作モード: DRY_RUN | TESTNET | LIVE ---
# DRY_RUN : 発注せずログ＆通知のみ（Phase 1）
# TESTNET : テストネットへ実発注（Phase 2, 例: bybit sandbox）
# LIVE    : 本番取引所へ実発注（Phase 3, 極小サイズ推奨）
TRADING_MODE=DRY_RUN

# --- TradingView Webhook と共有する秘密鍵（Pineのメッセージ内 secret と一致させる） ---
WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Discord 通知 ---
DISCORD_WEBHOOK_URL=

# --- 取引所（ccxt の exchange id）---
# Phase 2(TESTNET)は bybit（テストネットあり）で検証。
# Phase 3(LIVE)は bitbank（アルトの板取引が国内最大級・ccxt対応）。
#   検証中: EXCHANGE_ID=bybit   本番: EXCHANGE_ID=bitbank
EXCHANGE_ID=bybit
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# --- リスク制御 ---
# 1回の発注に使う金額（quote通貨=JPYやUSDT建て）。まずは極小額で。
ORDER_QUOTE_AMOUNT=1000
# 同時に持てる最大建玉数
MAX_OPEN_POSITIONS=1
# 同一シンボル+方向でこの秒数以内の連続発注を無視（二重/連打防止）
ORDER_COOLDOWN_SEC=60
# 許可するシンボル（カンマ区切り）。ここに無いシンボルは拒否。
# 本番(bitbank)でアルトを板取引する例。取引したい銘柄だけ残す。
#   bitbankの主なJPY板: BTC/JPY,ETH/JPY,XRP/JPY,SOL/JPY,DOGE/JPY,ADA/JPY,LTC/JPY,DOT/JPY ...
# ※TESTNET(bybit)検証時は BTC/USDT など bybit 側の表記に合わせて一時的に変更する。
ALLOWED_SYMBOLS=BTC/JPY,ETH/JPY,XRP/JPY,SOL/JPY,DOGE/JPY

# --- サーバ ---
HOST=0.0.0.0
PORT=8000
